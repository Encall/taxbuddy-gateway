# Backend Connections
# Local dev: localhost:8080 / localhost:8000
# Docker: backend:8080 / retreiver:8000
BACKEND_HOST=localhost:8080
RETREIVER_HOST=localhost:8000

# Database (for docker-compose backend service)
DATABASE_URL=postgres://username:password@db:5432/taxbuddy_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# S3/MinIO Storage (for backend)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_USE_SSL=false
